{
  "name": "skill-overlay",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Lost Ark skill-rotation editor + in-game overlay (monorepo).",
  "workspaces": [
    "packages/*",
    "apps/editor"
  ],
  "scripts": {
    "test": "npm run test --workspaces --if-present",
    "dev:editor": "npm run dev -w @skill-overlay/editor",
    "build:editor": "npm run build -w @skill-overlay/editor"
  },
  "allowScripts": {
    "esbuild@0.25.12": true,
    "esbuild@0.21.5": true
  }
}
