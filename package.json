{
  "name": "skill-overlay-editor",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Web editor for authoring Lost Ark skill-rotation flowcharts and exporting them for a game overlay.",
  "scripts": {
    "copy-media": "node scripts/copy-media.mjs",
    "predev": "node scripts/copy-media.mjs",
    "dev": "vite",
    "prebuild": "node scripts/copy-media.mjs",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@xyflow/react": "^12.3.5",
    "idb": "^8.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.23.8",
    "zundo": "^2.3.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.1",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.6.3",
    "vite": "^6.0.5",
    "vitest": "^4.1.9"
  },
  "allowScripts": {
    "esbuild@0.25.12": true,
    "esbuild@0.21.5": true
  }
}
